# wrangler dev（ローカル実行）用の Worker シークレット。
# コピーして .dev.vars を作成し、値を埋める（.dev.vars はコミットしない）。
# 本番環境へは wrangler secret put で Cloudflare に登録する（このファイルは使われない）。

# Discord Developer Portal > General Information > Public Key
DISCORD_PUBLIC_KEY=

# Discord Developer Portal > Bot > Token（チャンネル投稿用）
DISCORD_BOT_TOKEN=
